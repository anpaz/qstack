  keywords  = {Applied sciences ; Algorithmics. Computability. Computer arithmetics ; Theoretical computing ; Automata. Abstract machines. Turing machines ; Exact sciences and technology ; Computer science; control theory; systems ; Physics - Quantum Physics}
